# ── LLM Provider ──────────────────────────────────────
LLM_PROVIDER=openai              # "openai" or "anthropic"
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Models ────────────────────────────────────────────
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Chunking ──────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ─────────────────────────────────────────
TOP_K_VECTOR=10
TOP_K_BM25=10
TOP_K_FINAL=5
RRF_K=60

# ── Vector Store ──────────────────────────────────────
CHROMA_PERSIST_DIR=.chromadb
CHROMA_COLLECTION=hybrid_rag
